<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Google Homepage Clone</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    display:flex;
    flex-direction:column;
    min-height:100vh;
    background:#fff;
}

/* Navigation */

header{
    display:flex;
    justify-content:flex-end;
    align-items:center;
    padding:15px 30px;
}

header a{
    text-decoration:none;
    color:#202124;
    margin-left:20px;
    font-size:14px;
}

header a:hover{
    text-decoration:underline;
}

/* Main Section */

main{
    flex:1;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    margin-top:-80px;
}

/* Google Logo */

.logo{
    font-size:80px;
    font-weight:bold;
    margin-bottom:30px;
    user-select:none;
}

.blue{color:#4285F4;}
.red{color:#EA4335;}
.yellow{color:#FBBC05;}
.green{color:#34A853;}

/* Search Box */

.search-box{
    width:90%;
    max-width:580px;
    height:46px;
    border:1px solid #dcdcdc;
    border-radius:25px;
    display:flex;
    align-items:center;
    padding:0 18px;
    box-shadow:0 1px 6px rgba(32,33,36,.15);
}

.search-box input{
    width:100%;
    border:none;
    outline:none;
    font-size:16px;
    margin-left:10px;
}

.search-icon{
    color:#9aa0a6;
    font-size:18px;
}

/* Buttons */

.buttons{
    margin-top:30px;
}

.buttons button{
    padding:10px 18px;
    margin:5px;
    border:none;
    background:#f8f9fa;
    border:1px solid #f8f9fa;
    border-radius:4px;
    font-size:14px;
    cursor:pointer;
}

.buttons button:hover{
    border:1px solid #dadce0;
    box-shadow:0 1px 1px rgba(0,0,0,0.1);
}

/* Footer */

footer{
    background:#f2f2f2;
    padding:15px 30px;
}

.footer-links{
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
}

.footer-links a{
    text-decoration:none;
    color:#70757a;
    margin-right:15px;
    font-size:14px;
}

.footer-links a:hover{
    text-decoration:underline;
}

/* Responsive */

@media(max-width:600px){

.logo{
    font-size:60px;
}

.search-box{
    width:95%;
}

.footer-links{
    flex-direction:column;
    gap:10px;
}

}
</style>

</head>

<body>

<header>
    <a href="#">Gmail</a>
    <a href="#">Images</a>
</header>

<main>

    <div class="logo">
        <span class="blue">G</span>
        <span class="red">o</span>
        <span class="yellow">o</span>
        <span class="blue">g</span>
        <span class="green">l</span>
        <span class="red">e</span>
    </div>

    <div class="search-box">
        <span class="search-icon">&#128269;</span>
        <input type="text" placeholder="Search Google or type a URL">
    </div>

    <div class="buttons">
        <button>Google Search</button>
        <button>I'm Feeling Lucky</button>
    </div>

</main>

<footer>

<div class="footer-links">

<div>
<a href="#">About</a>
<a href="#">Advertising</a>
<a href="#">Business</a>
<a href="#">How Search works</a>
</div>

<div>
<a href="#">Privacy</a>
<a href="#">Terms</a>
<a href="#">Settings</a>
</div>

</div>

</footer>

</body>
</html>

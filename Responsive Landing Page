<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechNova - Landing Page</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            line-height:1.6;
            color:#333;
        }

        /* Header */
        header{
            background:linear-gradient(135deg,#4CAF50,#2E8B57);
            color:#fff;
            padding:20px 10%;
        }

        nav{
            display:flex;
            justify-content:space-between;
            align-items:center;
            flex-wrap:wrap;
        }

        nav h2{
            font-size:28px;
        }

        nav ul{
            list-style:none;
            display:flex;
            gap:20px;
        }

        nav ul li a{
            color:white;
            text-decoration:none;
            font-weight:bold;
        }

        .hero{
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:60px 0;
            gap:40px;
            flex-wrap:wrap;
        }

        .hero-text{
            flex:1;
        }

        .hero-text h1{
            font-size:42px;
            margin-bottom:20px;
        }

        .hero-text p{
            margin-bottom:20px;
        }

        .btn{
            display:inline-block;
            background:#fff;
            color:#2E8B57;
            padding:12px 25px;
            border-radius:5px;
            text-decoration:none;
            font-weight:bold;
        }

        .hero img{
            width:100%;
            max-width:400px;
            border-radius:10px;
        }

        /* Features */
        .features{
            padding:60px 10%;
            text-align:center;
        }

        .features h2{
            margin-bottom:40px;
        }

        .feature-container{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
        }

        .feature-box{
            background:#f4f4f4;
            padding:25px;
            border-radius:10px;
            box-shadow:0 2px 8px rgba(0,0,0,0.1);
        }

        .feature-box h3{
            margin-bottom:10px;
            color:#2E8B57;
        }

        /* Testimonials */
        .testimonials{
            background:#f9f9f9;
            padding:60px 10%;
            text-align:center;
        }

        .testimonial-container{
            display:flex;
            gap:20px;
            justify-content:center;
            flex-wrap:wrap;
            margin-top:30px;
        }

        .testimonial{
            background:white;
            padding:20px;
            width:300px;
            border-radius:10px;
            box-shadow:0 2px 8px rgba(0,0,0,0.1);
        }

        .testimonial h4{
            color:#2E8B57;
            margin-top:15px;
        }

        /* Footer */
        footer{
            background:#2E8B57;
            color:white;
            text-align:center;
            padding:20px;
        }

        /* Responsive Design */
        @media(max-width:768px){

            nav{
                flex-direction:column;
                gap:15px;
            }

            nav ul{
                flex-direction:column;
                text-align:center;
            }

            .hero{
                flex-direction:column;
                text-align:center;
            }

            .hero-text h1{
                font-size:32px;
            }
        }

    </style>
</head>

<body>

<header>

    <nav>
        <h2>TechNova</h2>

        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">Features</a></li>
            <li><a href="#">Reviews</a></li>
            <li><a href="#">Contact</a></li>
        </ul>
    </nav>

    <div class="hero">

        <div class="hero-text">
            <h1>Grow Your Business with TechNova</h1>

            <p>
                TechNova helps startups manage projects, collaborate with teams,
                and boost productivity using smart cloud solutions.
            </p>

            <a href="#" class="btn">Get Started</a>
        </div>

        <img src="https://via.placeholder.com/400x300" alt="Startup Image">

    </div>

</header>

<!-- Features -->

<section class="features">

    <h2>Our Features</h2>

    <div class="feature-container">

        <div class="feature-box">
            <h3>Cloud Storage</h3>
            <p>Securely store and access your files anytime, anywhere.</p>
        </div>

        <div class="feature-box">
            <h3>Fast Performance</h3>
            <p>Optimized tools that improve productivity and efficiency.</p>
        </div>

        <div class="feature-box">
            <h3>24/7 Support</h3>
            <p>Our expert support team is always available to help you.</p>
        </div>

    </div>

</section>

<!-- Testimonials -->

<section class="testimonials">

    <h2>What Our Customers Say</h2>

    <div class="testimonial-container">

        <div class="testimonial">
            <p>
                "TechNova transformed the way our team collaborates.
                Highly recommended!"
            </p>
            <h4>- Sarah</h4>
        </div>

        <div class="testimonial">
            <p>
                "Easy to use, reliable, and packed with useful features."
            </p>
            <h4>- John</h4>
        </div>

        <div class="testimonial">
            <p>
                "Excellent customer support and an amazing user experience."
            </p>
            <h4>- Emily</h4>
        </div>

    </div>

</section>

<!-- Footer -->

<footer>
    <p>&copy; 2026 TechNova. All Rights Reserved.</p>
</footer>

</body>
</html>
